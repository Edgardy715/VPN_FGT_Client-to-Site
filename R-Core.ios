!!! Configuracion de R-core
enable
configure terminal
hostname Rcore

!!! Interfaz hacia Firewall
int g0/0
ip addr 10.0.0.1 255.255.255.252
no sh
exit

!!! Interfaz hacia LAN Empresarial
int g0/1
ip addr 10.1.1.1 255.255.255.0
no sh
exit

!!! Ruta por defecto
ip route 0.0.0.0 0.0.0.0 10.0.0.2
end
write memory
